<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ThanhTho IT</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/bai1.styles.css" asp-append-version="true" />
    
    <style>
        body {
            background-color: #0b0c10;
            color: #c5c6c7;
            overflow-x: hidden; 
        }

        /* --- HIỆU ỨNG CYBERPUNK (HOLO CRT GLITCH) --- */
        
        .page-enter {
            animation: crtTurnOn 0.6s cubic-bezier(0.23, 1, 0.32, 1) forwards;
            transform-origin: 50% 15vh; /* Điểm bắt đầu hiệu ứng nằm ở góc trên màn hình */
        }
        .page-exit {
            animation: crtTurnOff 0.5s cubic-bezier(0.23, 1, 0.32, 1) forwards;
            transform-origin: 50% 15vh;
        }

        /* Lúc Load Trang: Từ 1 chấm bung ra đường thẳng -> bung xuống -> giật màu -> nét */
        @@keyframes crtTurnOn {
            0% { transform: scale(0.01, 0.01); filter: brightness(10) drop-shadow(0 0 50px #66fcf1); opacity: 0; }
            30% { transform: scale(1, 0.01); filter: brightness(5) drop-shadow(0 0 20px #66fcf1); opacity: 1; }
            60% { transform: scale(1, 1) skewX(5deg) translateX(10px); filter: brightness(2) drop-shadow(5px 0 0 red) drop-shadow(-5px 0 0 cyan); opacity: 1; }
            80% { transform: scale(1, 1) skewX(-2deg) translateX(-5px); filter: brightness(1.5) drop-shadow(-2px 0 0 red) drop-shadow(2px 0 0 cyan); opacity: 1; }
            100% { transform: scale(1, 1) skewX(0) translateX(0); filter: brightness(1); opacity: 1; }
        }

        /* Lúc Chuyển Trang: Giật màu -> ép thành đường thẳng -> thu lại thành 1 chấm */
        @@keyframes crtTurnOff {
            0% { transform: scale(1, 1) skewX(0); filter: brightness(1); opacity: 1; }
            20% { transform: scale(1, 1) skewX(-5deg) translateX(-10px); filter: brightness(2) drop-shadow(-5px 0 0 red) drop-shadow(5px 0 0 cyan); opacity: 1; }
            40% { transform: scale(1, 1) skewX(5deg) translateX(10px); filter: brightness(2) drop-shadow(5px 0 0 red) drop-shadow(-5px 0 0 cyan); opacity: 1; }
            60% { transform: scale(1, 0.01); filter: brightness(5) drop-shadow(0 0 20px #9d00ff); opacity: 1; }
            80% { transform: scale(0.01, 0.01); filter: brightness(10) drop-shadow(0 0 50px #9d00ff); opacity: 1; }
            100% { transform: scale(0, 0); filter: brightness(0); opacity: 0; }
        }
        /* ----------------------------------------------- */

        .navbar-custom {
            background-color: #1f2833 !important; 
            border-bottom: 1px solid rgba(102, 252, 241, 0.2) !important;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.5);
        }

        .navbar-brand {
            color: #fff !important; font-weight: 900; letter-spacing: 2px; text-transform: uppercase;
        }
        .navbar-brand span {
            color: #66fcf1; text-shadow: 0 0 10px rgba(102, 252, 241, 0.5);
        }

        .nav-link {
            transition: all 0.3s ease; border-bottom: 2px solid transparent; font-size: 0.95rem; letter-spacing: 1px; cursor: pointer;
        }
        .nav-link:hover {
            color: #66fcf1 !important; transform: translateY(-2px);
        }

        .neon-active {
            color: #66fcf1 !important; font-weight: 800; border-bottom: 2px solid #66fcf1; text-shadow: 0 0 10px rgba(102, 252, 241, 0.5);
        }

        .footer-custom {
            border-top: 1px solid rgba(102, 252, 241, 0.2) !important; color: #8b929a !important; background-color: #0b0c10;
        }
        .footer-custom a { color: #66fcf1; text-decoration: none; }
        .footer-custom a:hover { text-decoration: underline; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark navbar-custom mb-4 sticky-top">
            <div class="container-fluid px-lg-5">
                <a class="navbar-brand transition-link" asp-area="" asp-controller="Home" asp-action="Index">
                    
                </a>
                
                <button class="navbar-toggler border-info" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    @{
                        var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
                        var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
                    }

                    <ul class="navbar-nav mx-auto mb-2 mb-lg-0 fw-semibold">
                        <li class="nav-item mx-3">
                            <a class="nav-link py-3 transition-link @(currentController == "Home" && currentAction == "Index" ? "neon-active" : "text-light")" 
                               asp-area="" asp-controller="Home" asp-action="Index">TRANG CHỦ</a>
                        </li>
                        <li class="nav-item mx-3">
                            <a class="nav-link py-3 transition-link @(currentController == "Home" && currentAction == "SanPham" ? "neon-active" : "text-light")" 
                               asp-area="" asp-controller="Home" asp-action="SanPham">SẢN PHẨM</a>
                        </li>
                        <li class="nav-item mx-3">
                            <a class="nav-link py-3 transition-link @(currentController == "Home" && currentAction == "LienHe" ? "neon-active" : "text-light")" 
                               asp-area="" asp-controller="Home" asp-action="LienHe">LIÊN HỆ</a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center">
                        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-info rounded-pill px-4 fw-bold btn-sm transition-link" style="box-shadow: 0 0 10px rgba(102,252,241,0.3);">
    <i class="bi bi-person-circle me-2"></i>Đăng nhập
</a>
                </div>
            </div>
        </nav>
    </header>
    
    <div class="container-fluid px-lg-5 page-enter" id="main-content">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer footer-custom py-3 text-center">
        <div class="container">
            &copy; 2026 - Phát triển bởi <strong class="text-white">Triệu Thanh Tho</strong> (MSSV: 243913) - <a asp-area="" asp-controller="Home" asp-action="Privacy">Chính sách bảo mật</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const links = document.querySelectorAll('.transition-link');
            const mainContent = document.getElementById('main-content');

            links.forEach(link => {
                link.addEventListener('click', function(e) {
                    const href = this.getAttribute('href');
                    if (this.target === "_blank" || href === "#" || !href) return;

                    e.preventDefault();

                    // Chuyển sang hiệu ứng màn hình sập xuống
                    mainContent.classList.remove('page-enter');
                    mainContent.classList.add('page-exit');

                    // THAY ĐỔI NHỎ Ở ĐÂY: Tăng thời gian chờ lên 500ms để khớp với hiệu ứng chớp tắt
                    setTimeout(() => {
                        window.location.href = href;
                    }, 500); 
                });
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>