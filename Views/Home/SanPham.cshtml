                                        <h6 class="card-title text-truncate fw-bold">@item.Name</h6>
                                        <p class="text-secondary small mb-3">@item.Specs</p>
                                        <h4 class="text-primary fw-bold mb-2">@item.Price</h4>
                                        <div class="product-actions">
                                            <button class="btn btn-sm btn-outline-primary fw-bold" title="Thêm vào giỏ">
                                                <i class="bi bi-cart-plus"></i>
                                            </button>
                                            <button class="btn btn-sm btn-buy fw-bold text-uppercase">Mua ngay</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

            </div>
        </main>
    </div>
</div>

