<style>
    body { background-color: #0b0c10; }
    
    .tech-banner {
        position: relative;
        background: linear-gradient(135deg, #1f2833, #0b0c10, #45a29e);
        color: white;
        border-radius: 15px;
        overflow: hidden;
        border: 1px solid rgba(102, 252, 241, 0.2);
    }
    
    .tech-card {
        background-color: #1f2833;
        transition: all 0.4s ease;
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 12px;
        overflow: hidden;
    }
    
    .tech-card .card-title { color: #ffffff !important; font-size: 1.05rem; }
    
    .tech-card:hover {
        transform: translateY(-10px) scale(1.02);
        box-shadow: 0 15px 30px rgba(102, 252, 241, 0.2);
        border-color: #66fcf1;
        z-index: 10;
    }

    .tech-card img {
        background-color: #ffffff;
        border-bottom: 2px solid #333;
        height: 220px; 
        object-fit: cover;
    }

    .sidebar-menu .nav-link {
        background-color: transparent;
        color: #c5c6c7;
        border: none;
        border-radius: 0;
        border-left: 3px solid transparent;
        transition: all 0.2s ease;
        padding: 15px 20px;
        text-align: left;
        width: 100%;
        cursor: pointer;
    }
    
    .sidebar-menu .nav-link:hover, 
    .sidebar-menu .nav-link.active {
        background-color: rgba(102, 252, 241, 0.1);
        border-left: 3px solid #66fcf1;
        color: #66fcf1;
        font-weight: bold;
    }

    .section-title-neon {
        color: #ffffff;
        text-transform: uppercase;
        font-weight: 800;
        letter-spacing: 2px;
        text-shadow: 0 0 10px rgba(102, 252, 241, 0.5);
    }
    
    .student-info-block {
        background: linear-gradient(to top, #0b0c10, #1f2833);
        border-top: 2px solid #9d00ff;
    }

    .product-actions {
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 8px;
        margin-top: 15px;
    }
    
    .btn-buy {
        background: linear-gradient(45deg, #45a29e, #66fcf1);
        border: none;
        color: #0b0c10;
        transition: all 0.3s ease;
    }

    .btn-buy:hover {
        background: #66fcf1;
        box-shadow: 0 0 15px rgba(102, 252, 241, 0.4);
        transform: translateY(-2px);
        color: #000;
    }

    /* ======================================================== */
    /* HIỆU ỨNG TAB: HOLOGRAPHIC OVERDRIVE (RẤT NGẦU VÀ MÀU MÈ) */
    /* ======================================================== */
    
    /* Vô hiệu hóa fade mặc định */
    .tab-pane.fade { transition: none !important; }
    
    /* Khi tab được gọi lên */
    .tab-pane.active.show {
        animation: holoOverdrive 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
        transform-origin: center center;
    }

    @@keyframes holoOverdrive {
        0% { 
            opacity: 0; 
            transform: scale3d(2, 0.1, 1) translateY(-50px) skewX(30deg); 
            filter: hue-rotate(180deg) saturate(300%) drop-shadow(15px 15px 0px #ff00ff) drop-shadow(-15px -15px 0px #00ffff) blur(10px); 
        }
        30% {
            opacity: 0.8;
            transform: scale3d(1.1, 1.2, 1) translateY(20px) skewX(-15deg);
            filter: hue-rotate(90deg) saturate(250%) drop-shadow(5px 5px 0px #ff00ff) drop-shadow(-5px -5px 0px #00ffff) blur(4px);
        }
        50% {
            opacity: 1;
            transform: scale3d(0.95, 0.95, 1) translateY(-5px) skewX(5deg);
            filter: hue-rotate(45deg) saturate(150%) blur(1px);
        }
        70% {
            transform: scale3d(1.02, 1.02, 1) translateY(2px) skewX(-2deg);
            filter: hue-rotate(0deg) saturate(120%);
        }
        100% { 
            opacity: 1; 
            transform: scale3d(1, 1, 1) translateY(0) skewX(0); 
            filter: none; 
        }
    }
    /* ======================================================== */

</style>

<div class="container-fluid mt-4">
