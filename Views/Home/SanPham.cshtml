            </div>
        </aside>

        <main class="col-lg-9">
            <div class="tab-content" id="v-pills-tabContent">
                
                <div class="tab-pane fade show active" id="v-pills-laptop" role="tabpanel">
                    <h3 class="section-title-neon mb-4"><i class="bi bi-laptop text-info me-2"></i> LAPTOP & MACBOOK</h3>
                    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4 mb-5">
                        @foreach (var item in laptops)
                        {
                            <div class="col">
                                <div class="card h-100 tech-card" style="border-color: rgba(13, 202, 240, 0.3);">
                                    @if(!string.IsNullOrEmpty(item.Badge)) {
                                        <span class="badge bg-danger position-absolute top-0 end-0 m-3 px-3 py-2 rounded-pill shadow">@item.Badge</span>
                                    }
                                    <img src="@item.Img" class="card-img-top p-3" alt="@item.Name">
